# ==========================================================================
# Digital Signature Engine — Environment Variables Template
# ==========================================================================
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control!
# ==========================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME

# Set to True only for local development
DEBUG=False

# Comma-separated hostnames/domains
ALLOWED_HOSTS=your-domain.example.com

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
DB_NAME=signature_engine
DB_USER=sigengine_app
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432

# ---------------------------------------------------------------------------
# CORS — comma-separated origins
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

# ---------------------------------------------------------------------------
# Cryptographic Keys
# ---------------------------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HASH_CHAIN_GENESIS=CHANGE_ME
